PORT=3000

DB_USER=hconnect_user
DB_HOST=localhost
DB_NAME=hconnect_db
DB_PASSWORD=change_me
DB_PORT=5432

AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=https://hconnect-api
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_M2M_CLIENT_ID=your-m2m-client-id
AUTH0_M2M_CLIENT_SECRET=your-m2m-client-secret
AUTH0_DB_CONNECTION=Username-Password-Authentication

TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+10000000000

# Optional: comma-separated allowed origins for cloud/frontend domains
# Example: CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
CORS_ORIGIN=

# Optional SMS policy
SMS_CODE_LENGTH=4
SMS_CODE_TTL_MS=300000
